<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5 text-center">
    <h1>Order Submitted Successfully</h1>
    <p>Thank you for your order. Your request has been received.</p>

    <% if (order) { %>
        <div class="card mt-4 mx-auto" style="max-width: 500px;">
            <div class="card-body">
                <h4>Order Details</h4>
                <p><strong>Order ID:</strong> <%= order.Order_ID %></p>
                <p><strong>Status:</strong> <%= order.Status %></p>
            </div>
        </div>

        <a href="/order/track?orderId=<%= order.Order_ID %>" class="btn btn-info mt-3">
            Track This Order
        </a>
    <% } %>

    <div class="mt-3">
        <a href="/menu" class="btn btn-primary">Back to Menu</a>
        <a href="/order" class="btn btn-success">Place Another Order</a>
    </div>
    
    <% if (order) { %>
    <form action="/order/cancel" method="POST" style="display:inline;">
        <input type="hidden" name="orderId" value="<%= order.Order_ID %>">
        <button type="submit" class="btn btn-danger">Cancel Order</button>
    </form>
<% } %>
</div>


<%- include('partials/footer') %>