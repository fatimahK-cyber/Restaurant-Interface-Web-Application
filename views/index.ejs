<%- include('partials/header') %>

<div class="landing-page">
    <section class="modern-hero">
        <div class="hero-card">
            <div class="hero-badge">Fast • Fresh • Easy</div>

            <h1 class="hero-title">Restaurant Order System</h1>
            <p class="hero-subtitle">Fresh food delivered to your door</p>

            <div class="hero-actions">
                <form action="/set-role" method="POST" class="hero-form">
                    <button type="submit" name="role" value="customer" class="btn btn-primary-modern">
                        I’m a Customer
                    </button>
                </form>

                <form action="/set-role" method="POST" class="hero-form">
                    <button type="submit" name="role" value="employee" class="btn btn-secondary-modern">
                        I’m an Employee
                    </button>
                </form>
            </div>

            <div class="hero-actions hero-actions-secondary">
                <a href="/order" class="btn btn-primary-soft">Order Now</a>
                <a href="/menu" class="btn btn-secondary-modern">View Menu</a>
            </div>
        </div>
    </section>
</div>

<%- include('partials/footer') %>