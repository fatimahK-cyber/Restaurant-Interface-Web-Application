<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-4">
    <p>Customize and submit orders here.</p>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <h1 class="text-center mb-4">Make an Order</h1>

            <form action="/order" method="POST">
                <!-- Pick-up or Delivery -->
                <div class="mb-4">
                    <label for="orderType" class="form-label">Pick-up or delivery</label>
                    <select class="form-control" id="orderType" name="OrderType" required>
                        <option value="">Select option</option>
                        <option value="Pickup">Pick-up</option>
                        <option value="Delivery">Delivery</option>
                    </select>
                </div>

                <!-- Order Items -->
                <div class="mb-4">
                    <label class="form-label">Order Items</label>

                    <div id="orderItemsContainer">
                        <div class="row g-2 mb-3 order-item-row align-items-center">
                            <div class="col-md-3">
                                <select class="form-control category-select" name="ItemCategory[]" onchange="updateItems(this)" required>
                                    <option value="">Select category</option>
                                    <option value="Starter">Starter</option>
                                    <option value="Entree">Entree</option>
                                    <option value="Dessert">Dessert</option>
                                    <option value="Drink">Drink</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <select class="form-control item-select" name="ItemName[]" onchange="updateLineTotalFromItem(this)" required>
                                    <option value="">Select item</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <input type="number" class="form-control qty-input" name="ItemQty[]" value="1" min="1" onchange="updateLineTotal(this)" required>
                            </div>

                            <div class="col-md-2">
                                <input type="text" class="form-control line-total-display" placeholder="Total" readonly>
                            </div>

                            <div class="col-md-1">
                                <button type="button" class="btn btn-danger" onclick="removeItem(this)">X</button>
                            </div>
                        </div>
                    </div>

                    <button type="button" class="btn btn-outline-primary mt-2" onclick="addMoreItem()">+ Add More</button>
                </div>

                <!-- Order Total -->
                <div class="mb-4">
                    <label for="grandTotal" class="form-label"><strong>Order Total</strong></label>
                    <input type="text" id="grandTotal" name="GrandTotal" class="form-control" value="$0.00" readonly>
                </div>

                <!-- Customer Info -->
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input type="text" id="name" name="Name" class="form-control" placeholder="Enter your name" required>
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">Phone</label>
                    <input type="text" id="phone" name="Phone" class="form-control" placeholder="Enter your phone number" required>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" id="email" name="Email" class="form-control" placeholder="Enter your email" required>
                </div>

                <div class="mb-4">
                    <label for="address" class="form-label">Address</label>
                    <input type="text" id="address" name="Address" class="form-control" placeholder="Enter your address">
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const menuItems = {
        Starter: [
            { name: "Shrimp cocktail", price: 12.99 },
            { name: "French onion soup", price: 9.99 },
            { name: "Mushroom platter", price: 10.99 }
        ],
        Entree: [
            { name: "Filet mignon", price: 29.99 },
            { name: "Grilled salmon", price: 24.99 },
            { name: "Linguini pasta", price: 18.99 }
        ],
        Dessert: [
            { name: "Creme brulee", price: 8.99 },
            { name: "Honey cake", price: 7.99 },
            { name: "Royal custard", price: 6.99 }
        ],
        Drink: [
            { name: "Coke", price: 2.99 },
            { name: "Coke (diet)", price: 2.99 },
            { name: "Sprite", price: 2.99 },
            { name: "Iced tea", price: 3.49 },
            { name: "Bottled water", price: 1.99 }
        ]
    };

    function updateItems(categorySelect) {
        const row = categorySelect.closest('.order-item-row');
        const itemSelect = row.querySelector('.item-select');
        const qtyInput = row.querySelector('.qty-input');
        const lineTotalDisplay = row.querySelector('.line-total-display');
        const category = categorySelect.value;

        itemSelect.innerHTML = '<option value="">Select item</option>';
        qtyInput.value = 1;
        lineTotalDisplay.value = '';

        if (menuItems[category]) {
            menuItems[category].forEach(item => {
                const option = document.createElement('option');
                option.value = item.name;
                option.textContent = `${item.name} - $${item.price.toFixed(2)}`;
                option.setAttribute('data-price', item.price);
                itemSelect.appendChild(option);
            });
        }

        updateGrandTotal();
    }

    function updateLineTotalFromItem(itemSelect) {
        const row = itemSelect.closest('.order-item-row');
        const qtyInput = row.querySelector('.qty-input');
        const lineTotalDisplay = row.querySelector('.line-total-display');

        const selectedOption = itemSelect.options[itemSelect.selectedIndex];
        const price = parseFloat(selectedOption.getAttribute('data-price')) || 0;
        const qty = parseInt(qtyInput.value) || 1;

        lineTotalDisplay.value = price ? `$${(price * qty).toFixed(2)}` : '';
        updateGrandTotal();
    }

    function updateLineTotal(qtyInput) {
        const row = qtyInput.closest('.order-item-row');
        const itemSelect = row.querySelector('.item-select');
        const lineTotalDisplay = row.querySelector('.line-total-display');

        const selectedOption = itemSelect.options[itemSelect.selectedIndex];
        const price = parseFloat(selectedOption?.getAttribute('data-price')) || 0;
        const qty = parseInt(qtyInput.value) || 1;

        lineTotalDisplay.value = price ? `$${(price * qty).toFixed(2)}` : '';
        updateGrandTotal();
    }

    function updateGrandTotal() {
        const rows = document.querySelectorAll('.order-item-row');
        let total = 0;

        rows.forEach(row => {
            const itemSelect = row.querySelector('.item-select');
            const qtyInput = row.querySelector('.qty-input');
            const selectedOption = itemSelect.options[itemSelect.selectedIndex];

            const price = parseFloat(selectedOption?.getAttribute('data-price')) || 0;
            const qty = parseInt(qtyInput.value) || 1;

            total += price * qty;
        });

        document.getElementById('grandTotal').value = `$${total.toFixed(2)}`;
    }

    function addMoreItem() {
        const container = document.getElementById('orderItemsContainer');

        const row = document.createElement('div');
        row.className = 'row g-2 mb-3 order-item-row align-items-center';
        row.innerHTML = `
            <div class="col-md-3">
                <select class="form-control category-select" name="ItemCategory[]" onchange="updateItems(this)" required>
                    <option value="">Select category</option>
                    <option value="Starter">Starter</option>
                    <option value="Entree">Entree</option>
                    <option value="Dessert">Dessert</option>
                    <option value="Drink">Drink</option>
                </select>
            </div>

            <div class="col-md-4">
                <select class="form-control item-select" name="ItemName[]" onchange="updateLineTotalFromItem(this)" required>
                    <option value="">Select item</option>
                </select>
            </div>

            <div class="col-md-2">
                <input type="number" class="form-control qty-input" name="ItemQty[]" value="1" min="1" onchange="updateLineTotal(this)" required>
            </div>

            <div class="col-md-2">
                <input type="text" class="form-control line-total-display" placeholder="Total" readonly>
            </div>

            <div class="col-md-1">
                <button type="button" class="btn btn-danger" onclick="removeItem(this)">X</button>
            </div>
        `;

        container.appendChild(row);
    }

    function removeItem(button) {
        const rows = document.querySelectorAll('.order-item-row');
        if (rows.length > 1) {
            button.closest('.order-item-row').remove();
            updateGrandTotal();
        }
    }
</script>

<%- include('partials/footer') %>

