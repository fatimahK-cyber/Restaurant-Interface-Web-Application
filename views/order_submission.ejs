<%- include('partials/header') %>
<%- include('partials/navbar') %>
<br>
Customize and submit orders here. 
<br> 

<div class="container p-5">
    <div class="row">
        <div class="offset-md-3 col-md-6 text-center">
            <h1><%= title %></h1>
            <form class="form" method="POST" action="/order">
                <div class="form-group">
                    <label for="typeSelect">Pick-up or delivery</label>
                    <select name="Type" id="typeSelect" class="form-select mb-2" required>
                        <option value="" disabled selected>Select option</option>
                        <option value="Pick-up">Pick-up</option>
                        <option value="Delivery">Delivery</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="entreesSelect">Entrees</label>
                    <select name="Entrees" id="entreesSelect" class="form-select mb-2" required>
                        <option value="" disabled selected>Select option</option>
                        <option value="Pick-up"></option>
                        <option value="Delivery"></option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="nameTextField">Name</label>
                    <input type="text" class="form-control" id="nameTextField" placeholder="Enter your name" name="Name" required>
                </div>
                <div class="form-group">
                    <label for="phoneTextField">Phone Number</label>
                    <input type="text" class="form-control" id="phoneTextField" placeholder="Enter a phone number" name="Phone" required>
                </div>
                <div class="form-group">
                    <label for="emailTextField">Email</label>
                    <input type="email" class="form-control" id="emailTextField" placeholder="Enter your email" name="Email" required>
                </div>
                <div class="form-group">
                    <label for="addressTextField">Address (delivery only)</label>
                    <input type="text" class="form-control" id="addressTextField" placeholder="Enter your address" name="Address" required>
                </div>
                <button class="btn btn-primary" type="submit">Submit<i class="fas fa-plus-circle"></i></button>  
                <a href="/" class="btn btn-warning">Cancel<i class="fas fa-undo"></i></a>    
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>