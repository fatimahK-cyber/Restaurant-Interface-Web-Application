<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5 text-center">
    <h1>Track Your Order</h1>
    <p>Check the current status of your order below.</p>

    <% if (message) { %>
        <div class="alert alert-warning mt-3">
            <%= message %>
        </div>
    <% } %>

    <% if (order) { %>
        <div class="card mt-4 mx-auto text-start" style="max-width: 500px;">
            <div class="card-body">
                <h4>Order Details</h4>
                <p><strong>Order ID:</strong> <%= order.Order_ID %></p>
                <p><strong>Status:</strong> <%= order.Status %></p>
                <% if (order.Order_Type) { %>
                    <p><strong>Order Type:</strong> <%= order.Order_Type %></p>
                <% } %>
                <% if (order.Entree) { %>
                    <p><strong>Entree:</strong> <%= order.Entree %></p>
                <% } %>
            </div>
        </div>
    <% } %>

        <div class="mt-3">
        <a href="/menu" class="btn btn-primary">Back to Menu</a>
        <a href="/order" class="btn btn-success">Place Another Order</a>
    </div>
    
    <% if (order) { %>
    <form action="/order/cancel" method="POST" style="display:inline;">
        <input type="hidden" name="orderId" value="<%= order.Order_ID %>">
        <br>
        <button type="submit" class="btn btn-danger">Cancel Order</button>
    </form>
<% } %>
</div>

<%- include('partials/footer') %>