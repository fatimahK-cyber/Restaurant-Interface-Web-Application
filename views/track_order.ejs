<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5">
    <div class="row">
        <div class="offset-md-3 col-md-6 text-center">
            <h1>Track Your Order</h1>
            <p>Enter your order ID below to check the status of your order.</p>

            <form>
                <div class="form-group mb-3">
                    <label for="orderIdField">Order ID</label>
                    <input type="text" class="form-control" id="orderIdField" placeholder="Enter your order ID">
                </div>
                <button class="btn btn-primary" type="submit">Track Order</button>
            </form>
        </div>
    </div>
</div>

